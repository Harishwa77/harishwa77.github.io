
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EchelonAI Platform Security Rules
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for private data while enabling role-based access for
     * professional interactions between founders and investors. Security is centered around the UserProfile 'userType'.
     *
     * Data Structure:
     * - /users/{userId}: Root profiles and private sub-collections (private_startups, analysisReports).
     * - /startups_for_investment/{startupId}: A shared collection for startups seeking funding.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Critical IDs (founderId, userId) are denormalized into documents or 
     *    embedded in paths to allow logic that doesn't require expensive cross-document lookups.
     * 2. Structural Segregation: Startups are separated into private drafts (/users/.../private_startups) 
     *    and public investment opportunities (/startups_for_investment) to simplify listing rules.
     * 3. Role-Based Access: The 'investor' role is verified by performing a lookup on the user's own profile 
     *    to grant read access to the investment pool.
     *
     * Denormalization for Authorization:
     * - 'founderId' is required on all Startup documents to verify ownership during writes.
     * - 'userId' is required on AnalysisReports to ensure only the creator can access them.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Combines ownership check with existence check for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * Fetches the user's role from their profile. 
     * Used sparingly for role-based read access to public collections.
     */
    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == role;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (create) User with UID 'abc' creates document '/users/abc'.
     * @deny (update) User with UID 'abc' tries to modify document '/users/xyz'.
     * @principle Ownership: Enforces that the document ID matches the authenticated user's UID.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Private startup drafts/data owned by a founder.
     * @path /users/{founderId}/private_startups/{startupId}
     * @allow (list) Founder 'abc' lists their own private startups.
     * @deny (get) Investor 'investor_1' tries to read founder 'abc's private startup.
     * @principle Path-based Authorization: Access is strictly limited to the user identified in the path.
     */
    match /users/{founderId}/private_startups/{startupId} {
      allow get, list: if isOwner(founderId);
      allow create: if isOwner(founderId) && request.resource.data.founderId == founderId;
      allow update: if isExistingOwner(founderId) && request.resource.data.founderId == founderId;
      allow delete: if isExistingOwner(founderId);
    }

    /**
     * @description Publicly listable startups for investment. Anyone signed in can list the pool.
     * @path /startups_for_investment/{startupId}
     * @allow (list) Any authenticated user can browse the investment pool.
     * @deny (update) User 'investor_1' tries to change the revenue of a startup they don't own.
     * @principle Discovery for All / Owner-Only Write: Allows ecosystem discovery while protecting data integrity.
     */
    match /startups_for_investment/{startupId} {
      // Allow browsing by any authenticated user for discovery
      allow get, list: if isSignedIn();
      
      // Only the founder can create or modify their investment listing.
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if resource != null && isOwner(resource.data.founderId) && request.resource.data.founderId == resource.data.founderId;
      allow delete: if resource != null && isOwner(resource.data.founderId);
    }

    /**
     * @description AI Analysis reports initiated by and private to a specific user.
     * @path /users/{userId}/analysisReports/{analysisReportId}
     * @allow (create) User 'abc' saves a new analysis report to their own subcollection.
     * @deny (list) User 'xyz' attempts to list reports belonging to user 'abc'.
     * @principle Relational Integrity: Ensures the 'userId' field matches the path and the authenticated user.
     */
    match /users/{userId}/analysisReports/{analysisReportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}
